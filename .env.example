DATABASE_URL="postgresql://helpdesk_modern:helpdesk_modern@127.0.0.1:5432/helpdesk_modern"

AUTH_SECRET= # generate with: npx auth secret
NEXTAUTH_URL="http://localhost:3000"

# Required in production when running behind a reverse proxy (Railway, Vercel,
# etc.) — without it Auth.js v5 rejects requests with "UntrustedHost". Not
# needed for local dev.
AUTH_TRUST_HOST="true"

# Optional: enables the "Continue with Google" button. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials with redirect URI
# {NEXTAUTH_URL}/api/auth/callback/google. Leave both unset to hide the button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Groq's free OpenAI-compatible API — get a free key at https://console.groq.com/keys.
# Leave OPENAI_BASE_URL unset to use OpenAI itself.
OPENAI_API_KEY=
OPENAI_BASE_URL="https://api.groq.com/openai/v1"
OPENAI_MODEL="llama-3.3-70b-versatile"

WEBHOOK_SECRET= # Required for the inbound email webhook

# SMTP for outbound agent replies. For Gmail: enable 2FA, then create an App
# Password at https://myaccount.google.com/apppasswords — use that, not your
# normal password. Leave MAIL_HOST unset to disable sending (logs instead).
MAIL_HOST= # e.g. smtp.gmail.com
MAIL_PORT="587"
MAIL_USERNAME= # Full email address
MAIL_PASSWORD= # App password
MAIL_FROM_ADDRESS= # Usually same as MAIL_USERNAME
MAIL_FROM_NAME="Sahaydesk"

# IMAP for inbound ticket creation — run `npm run imap:poll` as a separate process.
# Only unread messages whose Subject contains IMAP_SUBJECT_FILTER become tickets;
# everything else in the inbox (including its read/unread flag) is left untouched.
IMAP_HOST= # e.g. imap.gmail.com
IMAP_PORT="993"
IMAP_SECURE="true"
IMAP_USERNAME= # Full email address
IMAP_PASSWORD= # App password
IMAP_POLL_INTERVAL_MS="90000" # 90000ms = 1.5 min
IMAP_SUBJECT_FILTER="ticket"
